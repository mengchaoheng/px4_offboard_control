Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Grid1
        - /Reference Path1
        - /Actual Tail1
        - /Reference Pose1
        - /Actual Pose1
      Splitter Ratio: 0.5
    Tree Height: 372
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ""
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 20
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/TF
      Enabled: true
      Filter (blacklist): ""
      Filter (whitelist): ""
      Frame Timeout: 15
      Frames:
        All Enabled: true
        base_link:
          Value: true
        base_link_frd:
          Value: true
        map:
          Value: true
        map_ned:
          Value: true
        odom:
          Value: true
        odom_ned:
          Value: true
      Marker Alpha: 1
      Marker Scale: 0.800000011920929
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Tree:
        base_link:
          base_link_frd:
            {}
        map:
          map_ned:
            {}
        odom:
          odom_ned:
            {}
      Update Interval: 0
      Value: true
    - Alpha: 1
      Buffer Length: 1
      Class: rviz/Path
      Color: 206; 92; 0
      Enabled: true
      Head Diameter: 0.18000000715255737
      Head Length: 0.20000000298023224
      Length: 0.3499999940395355
      Line Style: Lines
      Line Width: 0.05000000074505806
      Name: Reference Path
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color: 0; 255; 0
      Pose Style: None
      Queue Size: 10
      Radius: 0.029999999329447746
      Shaft Diameter: 0.05000000074505806
      Shaft Length: 0.20000000298023224
      Topic: /reference_path
      Unreliable: false
      Value: true
    - Alpha: 1
      Buffer Length: 1
      Class: rviz/Path
      Color: 32; 74; 135
      Enabled: true
      Head Diameter: 0.18000000715255737
      Head Length: 0.20000000298023224
      Length: 0.3499999940395355
      Line Style: Lines
      Line Width: 0.07999999821186066
      Name: Actual Tail
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color: 255; 80; 80
      Pose Style: None
      Queue Size: 10
      Radius: 0.029999999329447746
      Shaft Diameter: 0.05000000074505806
      Shaft Length: 0.20000000298023224
      Topic: /actual_path_tail
      Unreliable: false
      Value: true
    - Alpha: 1
      Axes Length: 0.699999988079071
      Axes Radius: 0.03999999910593033
      Class: rviz/Pose
      Color: 252; 175; 62
      Enabled: true
      Head Length: 0.3499999940395355
      Head Radius: 0.11999999731779099
      Name: Reference Pose
      Queue Size: 10
      Shaft Length: 0.550000011920929
      Shaft Radius: 0.03999999910593033
      Shape: Arrow
      Topic: /reference_pose
      Unreliable: false
      Value: true
    - Alpha: 1
      Axes Length: 0.699999988079071
      Axes Radius: 0.03999999910593033
      Class: rviz/Pose
      Color: 114; 159; 207
      Enabled: true
      Head Length: 0.3499999940395355
      Head Radius: 0.11999999731779099
      Name: Actual Pose
      Queue Size: 10
      Shaft Length: 0.550000011920929
      Shaft Radius: 0.03999999910593033
      Shape: Arrow
      Topic: /actual_pose
      Unreliable: false
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 15.680000305175781
