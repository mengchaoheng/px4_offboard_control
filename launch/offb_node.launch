<launch>
    <!-- <node name="offb_dataset_node" pkg="px4_offboard_control" type="offb_dataset_node" output="screen"> --> <!-- trajectory from  data-->
    <!-- <node name="offboard_node" pkg="px4_offboard_control" type="offboard_node" output="screen"> --> <!-- to a setpoint-->
    <node name="offb_node" pkg="px4_offboard_control" type="offb_node" output="screen"> <!-- Lissajous-->
        <param name="setpoint_raw_mode" type="bool" value="true" />
        <param name="use_bag" type="bool" value="true" />
        <remap from="~/setpoint_raw/local" to="mavros/setpoint_raw/local"/>
        <remap from="~/setpoint_position/local" to="mavros/setpoint_position/local"/>
        <remap from="~/cmd/arming" to="mavros/cmd/arming"/>
        <remap from="~/state" to="mavros/state"/>
        <remap from="~/set_mode" to="mavros/set_mode"/>
    </node>
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find px4_offboard_control)/config/config_file.rviz" />
</launch>
